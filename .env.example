# Google Gemini API 密钥（必填）
# 申请地址：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ChromaDB 向量数据库存储路径
CHROMA_DB_PATH=./data/chroma_db

# Gemini 模型名称
MODEL_NAME=gemini-2.0-flash

# Google Embedding 模型名称
EMBEDDING_MODEL=models/embedding-001

# FastAPI 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Gradio 前端配置
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860

# RAG 检索配置
RAG_TOP_K=3
DOCS_DIR=./app/rag/docs
